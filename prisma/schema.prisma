// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String?
  company       String?
  cnpj          String?
  regime        String?  // lucro_real, lucro_presumido, simples
  role          String   @default("user") // user, admin, partner

  // Se for cliente convidado por parceiro
  invitedByPartnerId String?
  invitedByPartner   Partner? @relation("InvitedUsers", fields: [invitedByPartnerId], references: [id])
  inviteCode         String?  // codigo usado no cadastro

  // Endereco da empresa
  endereco           String?
  cidade             String?
  estado             String?
  cep                String?
  
  // Dados do representante legal
  legalRepName       String?
  legalRepCpf        String?
  legalRepRg         String?
  legalRepCargo      String?  // Ex: Socio-Administrador, Diretor
  legalRepEmail      String?
  legalRepPhone      String?
  
  // Dados bancarios do cliente
  bankName           String?  // Ex: Banco do Brasil, Itau
  bankAgency         String?  // Agencia
  bankAccount        String?  // Conta corrente
  bankAccountType    String?  // corrente, poupanca
  bankPixKey         String?  // Chave PIX
  bankAccountHolder  String?  // Titular da conta
  bankCpfCnpj        String?  // CPF/CNPJ do titular
  
  onboardingComplete Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  batchJobs     BatchJob[]
  documents     Document[]
  contracts     Contract[] @relation("ClientContracts")
  
  @@index([email])
  @@index([invitedByPartnerId])
}

// ============================================
// PARCEIRO (Advogado Tributarista, Escritorio)
// ============================================
model Partner {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  oabNumber     String?  // Registro OAB
  oabState      String?  // UF da OAB
  company       String?  // Nome do escritorio
  cnpj          String?
  phone         String?
  
  // Endereco do escritorio
  endereco      String?
  cidade        String?
  estado        String?
  cep           String?
  
  // Dados bancarios do parceiro
  bankName           String?
  bankAgency         String?
  bankAccount        String?
  bankAccountType    String?
  bankPixKey         String?
  bankAccountHolder  String?
  bankCpfCnpj        String?
  
  // Configuracao de comissao sobre creditos recuperados
  commissionPercent Float   @default(40) // % que o parceiro recebe
  
  // Status: pending_approval, active, suspended
  status        String   @default("pending_approval")
  approvedAt    DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relacoes
  viabilityAnalyses ViabilityAnalysis[]
  invites           ClientInvite[]
  contracts         Contract[]
  invitedUsers      User[] @relation("InvitedUsers")
  
  @@index([email])
  @@index([status])
}

// ============================================
// ANALISE DE VIABILIDADE (score rapido)
// ============================================
model ViabilityAnalysis {
  id            String   @id @default(uuid())
  partnerId     String?
  partner       Partner?  @relation(fields: [partnerId], references: [id])
  
  // Dados da empresa alvo
  companyName   String
  cnpj          String?
  regime        String?  // lucro_real, lucro_presumido, simples
  sector        String?  // Setor de atuacao
  annualRevenue Float?   // Faturamento anual estimado

  // Autorizacao e entrevista (seguranca juridica)
  authorizedByNames   String?  // "Joao Silva, Maria Santos" — socios que autorizaram
  authorizedByCargos  String?  // "Socio-Administrador"
  interviewData       String?  @db.Text // JSON: folha, energia, acoes judiciais, etc.
  dataSources         String?  @db.Text // JSON: [{tipo:"SPED",periodo:"2020-2024"},{tipo:"DARF",mes:"03/2025"}]
  
  // Documentos enviados para analise rapida
  docsUploaded  Int      @default(0)
  docsText      String?  @db.Text // texto extraido para analise
  
  // Resultado da IA
  viabilityScore  Int?     // 0-100
  scoreLabel      String?  // "excelente", "bom", "medio", "baixo", "inviavel"
  estimatedCredit Float?   // Valor estimado de credito
  opportunities   String?  @db.Text // JSON resumo de oportunidades
  aiSummary       String?  @db.Text // Parecer rapido da IA
  risks           String?  @db.Text // JSON riscos identificados
  
  // Status: pending, analyzing, completed, expired
  status        String   @default("pending")
  
  // Se virou contrato
  convertedToContractId String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([partnerId])
  @@index([status])
  @@index([viabilityScore])
}

// ============================================
// CONVITE (parceiro gera codigo para cliente)
// ============================================
model ClientInvite {
  id            String   @id @default(uuid())
  partnerId     String
  partner       Partner  @relation(fields: [partnerId], references: [id])
  
  // Codigo de acesso unico
  inviteCode    String   @unique
  
  // Dados do cliente alvo
  clientEmail   String?
  clientName    String?
  companyName   String
  cnpj          String?
  
  // Referencia a viabilidade
  viabilityAnalysisId String?
  
  // Status: active, used, expired, revoked
  status        String   @default("active")
  usedAt        DateTime?
  usedByUserId  String?  // User que usou o convite
  
  expiresAt     DateTime // Validade do convite
  createdAt     DateTime @default(now())
  
  @@index([inviteCode])
  @@index([partnerId])
  @@index([status])
}

// ============================================
// CONTRATO DIGITAL
// ============================================
model Contract {
  id            String   @id @default(uuid())
  
  // Tipo: bipartite (TaxCredit + Cliente) ou tripartite (TaxCredit + Cliente + Parceiro)
  contractType  String   @default("tripartite") // bipartite | tripartite
  
  // Partes — partnerId opcional (null no bipartite)
  partnerId     String?
  partner       Partner?  @relation(fields: [partnerId], references: [id])
  clientId      String
  client        User     @relation("ClientContracts", fields: [clientId], references: [id])
  
  // Taxa de adesao (padrao R$ 2.000, 100% plataforma)
  setupFee            Float    @default(2000)
  setupFeePartner     Float    @default(0)
  setupFeePlatform    Float    @default(2000)
  setupFeePaid        Boolean  @default(false)
  setupFeePaidAt      DateTime?
  
  // Split sobre creditos recuperados (novo modelo: cliente fica com a maior parte)
  clientSplitPercent   Float  @default(80)  // % cliente (padrao 80%)
  platformSplitPercent Float  @default(20)  // % TaxCredit (20% bipartite, 12% tripartite)
  partnerSplitPercent  Float  @default(0)   // % parceiro (0% bipartite, 8% tripartite)
  
  // Apos pagamento da taxa, libera:
  consultaLiberada     Boolean @default(false)
  formalizacaoLiberada Boolean @default(false)
  
  // Detalhes do contrato
  contractNumber  String  @unique
  contractText    String? @db.Text
  
  // Advogado vinculado
  lawyerName       String?
  lawyerOab        String?  // Ex: "RJ 123.456"
  
  // Conta escrow Banco Fibra
  escrowAgencia    String?
  escrowConta      String?
  
  // Valor estimado de creditos (da analise)
  estimatedCredits Float?
  
  // Assinaturas
  partnerSignedAt  DateTime?
  clientSignedAt   DateTime?
  partnerSignatureIp String?
  clientSignatureIp  String?
  
  // Status: draft, pending_payment, payment_claimed, pending_signatures, active, completed, cancelled
  status          String  @default("draft")
  
  // Checklist de acompanhamento (JSON com estados booleanos)
  checklist        Json?
  
  // Valores realizados
  totalRecovered   Float   @default(0)
  clientEarnings   Float   @default(0)
  partnerEarnings  Float   @default(0)
  platformEarnings Float   @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([partnerId])
  @@index([clientId])
  @@index([status])
  @@index([contractType])
}

model BatchJob {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name              String?
  status            String   @default("pending") // pending, processing, completed, failed
  totalDocuments    Int      @default(0)
  processedDocs     Int      @default(0)
  failedDocs        Int      @default(0)
  
  // Totais consolidados
  totalEstimatedValue Float  @default(0)
  totalOpportunities  Int    @default(0)
  
  // Metadados
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  documents         Document[]
  consolidatedReport String?  @db.Text // JSON do relatório consolidado
  
  @@index([userId, status])
  @@index([createdAt])
}

model Document {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  batchJobId        String?
  batchJob          BatchJob? @relation(fields: [batchJobId], references: [id], onDelete: SetNull)
  
  // Informações do documento
  fileName          String
  fileSize          Int
  mimeType          String
  documentType      String   // dre, balanço, balancete
  
  // Extração automática
  extractedPeriod   String?  // "2024-Q1", "2023", "2024-01"
  extractedYear     Int?
  extractedMonth    Int?
  extractedQuarter  Int?
  
  // Dados da empresa
  companyName       String?
  cnpj              String?
  regime            String?
  
  // Status do processamento
  status            String   @default("pending") // pending, processing, completed, failed, ocr_needed
  processingError   String?  @db.Text
  
  // Texto extraído
  extractedText     String?  @db.Text
  
  // Timestamps
  uploadedAt        DateTime @default(now())
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  analysis          Analysis?
  
  @@index([userId, status])
  @@index([batchJobId])
  @@index([extractedYear, extractedMonth])
}

model Analysis {
  id                String   @id @default(uuid())
  documentId        String   @unique
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // Resultado da análise
  opportunities     String   @db.Text // JSON array of TaxCreditOpportunity
  executiveSummary  String   @db.Text
  totalEstimatedValue Float
  recommendations   String   @db.Text // JSON array
  alerts            String   @db.Text // JSON array
  
  // Metadados da análise
  modelUsed         String   // claude-opus-4-20250514 ou claude-sonnet-4-20250514
  tokensUsed        Int?
  processingTimeMs  Int?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  taxCreditProcesses TaxCreditProcess[]
  
  @@index([totalEstimatedValue])
  @@index([createdAt])
}

model TaxCreditProcess {
  id                String   @id @default(uuid())
  analysisId        String
  analysis          Analysis @relation(fields: [analysisId], references: [id])
  
  opportunityIndex  Int
  opportunityType   String
  estimatedValue    Float
  
  // Status: docs_generated, ready_to_file, filed, approved, rejected
  status            String   @default("docs_generated")
  
  // Documentacao
  docsGeneratedAt   DateTime @default(now())
  docsZipPath       String?
  
  // Protocolo
  protocolNumber    String?
  protocolDate      DateTime?
  
  // Acompanhamento
  responseStatus    String?
  recoveredValue    Float?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([status])
}

model SystemConfig {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String   @db.Text
  description       String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// TESES TRIBUTARIAS (atualizaveis sem deploy)
// ============================================
model TaxThesis {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String
  description       String    @db.Text
  tributo           String
  fundamentacao     String    @db.Text
  tribunal          String?
  tema              String?
  status            String    @default("active")
  risco             String    @default("medio")
  probabilidade     Int       @default(70)
  setoresAplicaveis String?   @db.Text
  regimesAplicaveis String?   @db.Text
  formulaCalculo    String?   @db.Text
  fonte             String?
  dataDecisao       DateTime?
  ativo             Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tributo])
  @@index([status])
  @@index([ativo])
}

model ThesisUpdate {
  id          String    @id @default(cuid())
  type        String
  title       String
  description String    @db.Text
  source      String?
  tribunal    String?
  relevance   String    @default("medium")
  thesisCode  String?
  reviewed    Boolean   @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?
  approved    Boolean?
  createdAt   DateTime  @default(now())

  @@index([reviewed])
  @@index([relevance])
}

// ============================================
// JURISPRUDENCIA VINCULANTE — Ajuste de probabilidade por tese
// Claude consulta antes de atribuir probabilidade
// ============================================
model TeseJurisprudencia {
  id                    String    @id @default(cuid())
  teseId                String?   // codigo da tese (ex: 3.2, 20_SM)
  teseCodigo            String    // "3.2", "20_SM" — para matching
  temaVinculante        String?   // "Tema 1.079", "Tema 1.390"
  tribunal              String?   // "STJ", "STF"
  dataJulgamento        DateTime?
  resultado             String    // FAVORAVEL, DESFAVORAVEL, PARCIAL
  probabilidadeMaxima   Int?      // ex: 10 para desfavoravel
  modulacao             String?   @db.Text
  notas                 String?   @db.Text
  ativo                 Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([teseCodigo])
  @@index([ativo])
}

// ============================================
// PROCURACOES
// ============================================
// ============================================
// COMPLIANCE EM TEMPO REAL
// ============================================
model ComplianceMonitor {
  id               String    @id @default(uuid())
  
  // Empresa monitorada
  companyName      String
  cnpj             String
  regime           String?
  sector           String?
  
  // Configuração
  active           Boolean   @default(true)
  autoAnalyze      Boolean   @default(true)
  
  // Contadores
  totalUploads     Int       @default(0)
  totalAlerts      Int       @default(0)
  totalEconomia    Float     @default(0)
  lastUploadAt     DateTime?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  uploads          ComplianceUpload[]
  alerts           ComplianceAlert[]
  
  @@unique([cnpj])
  @@index([active])
  @@index([cnpj])
}

model ComplianceUpload {
  id               String    @id @default(uuid())
  monitorId        String
  monitor          ComplianceMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  
  // Arquivo
  fileName         String
  fileSize         Int
  spedType         String    // efd-icms, efd-contribuicoes, ecf, ecd
  
  // Período do SPED
  periodoInicio    String?
  periodoFim       String?
  ano              Int?
  mes              Int?
  
  // Resultado da análise
  status           String    @default("pending") // pending, analyzing, completed, failed
  totalCreditos    Float     @default(0)
  totalDebitos     Float     @default(0)
  alertasGerados   Int       @default(0)
  resumoJson       String?   @db.Text
  
  processedAt      DateTime?
  createdAt        DateTime  @default(now())
  
  alerts           ComplianceAlert[]
  
  @@index([monitorId])
  @@index([status])
  @@index([ano, mes])
}

model ComplianceAlert {
  id               String    @id @default(uuid())
  monitorId        String
  monitor          ComplianceMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  uploadId         String?
  upload           ComplianceUpload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  
  // Classificação
  severity         String    // critical, warning, info
  category         String    // overpayment, missing_credit, wrong_rate, wrong_cfop, retention_excess, base_error
  tributo          String    // ICMS, PIS, COFINS, IRPJ, CSLL
  
  // Detalhes
  title            String
  description      String    @db.Text
  valorEnvolvido   Float     @default(0)
  economiaEstimada Float     @default(0)
  
  // Fundamentação
  baseLegal        String?   @db.Text
  registroSped     String?
  parecer          String?   @db.Text
  
  // Status do alerta
  status           String    @default("new") // new, reviewed, accepted, dismissed, resolved
  reviewedAt       DateTime?
  reviewedBy       String?
  resolvedAt       DateTime?
  
  periodo          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  @@index([monitorId])
  @@index([severity])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model Procuration {
  id               String    @id @default(cuid())
  contractId       String?
  clientId         String
  partnerId        String?
  type             String    // particular, ecac_guide, sefaz
  lawyerScenario   String    // atom_lawyer, partner_lawyer, client_lawyer
  status           String    @default("generated")
  outorgadoAtom    Boolean   @default(true)
  outorgadoAdv     Boolean   @default(false)
  advogadoNome     String?
  advogadoOab      String?
  advogadoCpf      String?
  advogadoEndereco String?
  uf               String?
  prazoAnos        Int       @default(2)
  poderes          Json?
  documentText     String?   @db.Text
  dataAssinatura   DateTime?
  dataValidade     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clientId])
  @@index([contractId])
  @@index([partnerId])
  @@index([status])
}

// ========================================
// Simples Recovery — Recuperação Simples Nacional
// ========================================

model SimplesAnalysis {
  id               String    @id @default(cuid())
  cnpj             String
  companyName      String
  regime           String    @default("simples_nacional")
  
  totalRecuperavel   Float   @default(0)
  totalMonofasico    Float   @default(0)
  totalIcmsSt        Float   @default(0)
  totalOutros        Float   @default(0)
  
  periodoInicio    String?
  periodoFim       String?
  mesesAnalisados  Int       @default(0)
  
  totalNfes        Int       @default(0)
  totalItens       Int       @default(0)
  
  resumoJson       Json?
  status           String    @default("completed")
  
  items            SimplesRecoveryItem[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  @@index([cnpj])
  @@index([createdAt])
}

model SimplesRecoveryItem {
  id              String   @id @default(cuid())
  analysisId      String
  analysis        SimplesAnalysis @relation(fields: [analysisId], references: [id])
  
  tipo            String   // monofasico_pis, monofasico_cofins, icms_st, outro
  tributo         String   // PIS, COFINS, ICMS
  ncm             String?
  descricaoProduto String?
  
  baseCalculo     Float    @default(0)
  aliquotaDas     Float    @default(0)
  valorPagoIndevido Float  @default(0)
  valorRecuperavel  Float  @default(0)
  
  competencia     String?
  baseLegal       String?  @db.Text
  
  createdAt       DateTime @default(now())
  
  @@index([analysisId])
  @@index([tipo])
  @@index([ncm])
}
